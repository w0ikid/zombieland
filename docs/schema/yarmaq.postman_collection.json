  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "const services = [\"ACCOUNTS\", \"TRANSACTIONS\"];\r",
          "\r",
          "const env = pm.environment.get(\"environment\"); // \"local\" или \"dev\"\r",
          "\r",
          "services.forEach(service => {\r",
          "    const urlVar = env === \"dev\"\r",
          "        ? `${service}_URL_DEV`\r",
          "        : `${service}_URL_LOCAL`;\r",
          "    \r",
          "    // Устанавливаем базовый URL для сервиса\r",
          "    pm.environment.set(`${service}_URL`, pm.environment.get(urlVar));\r",
          "});"
        ]
      }
    },
